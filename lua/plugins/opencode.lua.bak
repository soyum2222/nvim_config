-- opencode.nvim - 集成 opencode AI 助手到 Neovim
-- 提供 Cursor 风格的 AI 编程体验，包括上下文感知的代码生成和对话
return {
	{
		"nickjvandyke/opencode.nvim",
		version = "*", -- 使用最新稳定版本
		dependencies = {
			{
				-- snacks.nvim 集成（推荐但可选）
				-- 提供更好的输入和选择器体验
				"folke/snacks.nvim",
				optional = true,
				opts = {
					input = {}, -- 增强 ask() 功能
					picker = { -- 增强 select() 功能
						actions = {
							opencode_send = function(...) 
								return require("opencode").snacks_picker_send(...) 
							end,
						},
						win = {
							input = {
								keys = {
									["<a-a>"] = { "opencode_send", mode = { "n", "i" } },
								},
							},
						},
					},
				},
			},
		},
		config = function()
			-- opencode.nvim 配置
			---@type opencode.Opts
			vim.g.opencode_opts = {
				-- 服务器配置 - 使用 TUI 模式而不是独立服务器
				server = {
					-- 使用内嵌终端启动 opencode TUI
					start = function()
						-- 在右侧打开 opencode TUI
						vim.cmd('vsplit | terminal opencode --port')
					end,
					
					stop = function()
						-- 关闭 opencode 终端
						vim.cmd('bdelete! term://*opencode*')
					end,
					
					toggle = function()
						-- 切换 opencode 终端显示
						local opencode_buffers = vim.tbl_filter(function(buf)
							local name = vim.api.nvim_buf_get_name(buf)
							return name:match('term://.*opencode')
						end, vim.api.nvim_list_bufs())
						
						if #opencode_buffers > 0 then
							-- 如果存在，关闭它
							for _, buf in ipairs(opencode_buffers) do
								vim.cmd('bdelete! ' .. buf)
							end
						else
							-- 如果不存在，启动它
							vim.cmd('vsplit | terminal opencode --port')
						end
					end,
				},
				
				-- LSP 集成（实验性功能）
				lsp = {
					enabled = false, -- 设为 true 启用 LSP 集成
				},
				
				-- 事件处理
				events = {
					reload = true, -- 自动重载被 opencode 编辑的文件
				},
				
				-- 自定义 prompts
				prompts = {
					-- 可以在这里添加自定义的 prompt
					code_review = "Please review this code for bugs, performance issues, and best practices: @this",
					refactor = "Please refactor this code to make it more readable and maintainable: @this",
					optimize = "Please optimize this code for better performance: @this",
					test = "Please generate comprehensive tests for this code: @this",
				},
			}

			-- 必需：启用自动重载（用于 opencode 编辑文件后同步）
			vim.o.autoread = true

			-- 推荐的快捷键配置
			-- 主要 AI 对话快捷键
			vim.keymap.set({ "n", "x" }, "<C-a>", function() 
				require("opencode").ask("@this: ", { submit = true }) 
			end, { desc = "Ask opencode AI..." })
			
			vim.keymap.set({ "n", "x" }, "<C-x>", function() 
				require("opencode").select() 
			end, { desc = "Execute opencode action..." })
			
			vim.keymap.set({ "n", "t" }, "<C-.>", function() 
				require("opencode").toggle() 
			end, { desc = "Toggle opencode terminal" })

			-- 操作符模式快捷键（支持范围和点重复）
			vim.keymap.set({ "n", "x" }, "go", function() 
				return require("opencode").operator("@this ") 
			end, { desc = "Add range to opencode", expr = true })
			
			vim.keymap.set("n", "goo", function() 
				return require("opencode").operator("@this ") .. "_" 
			end, { desc = "Add line to opencode", expr = true })

			-- opencode 终端滚动快捷键
			vim.keymap.set("n", "<S-C-u>", function() 
				require("opencode").command("session.half.page.up") 
			end, { desc = "Scroll opencode up" })
			
			vim.keymap.set("n", "<S-C-d>", function() 
				require("opencode").command("session.half.page.down") 
			end, { desc = "Scroll opencode down" })

			-- 由于使用了 <C-a> 和 <C-x>，重新映射原有的增减功能
			vim.keymap.set("n", "+", "<C-a>", { desc = "Increment under cursor", noremap = true })
			vim.keymap.set("n", "-", "<C-x>", { desc = "Decrement under cursor", noremap = true })

			-- 更多有用的快捷键
			vim.keymap.set("n", "<leader>oo", function() 
				require("opencode").ask("", { submit = false }) 
			end, { desc = "Open opencode prompt" })
			
			vim.keymap.set("n", "<leader>op", function() 
				require("opencode").select() 
			end, { desc = "Select opencode prompt" })
			
			vim.keymap.set("n", "<leader>ot", function() 
				require("opencode").toggle() 
			end, { desc = "Toggle opencode" })

			-- 针对不同场景的预设 prompts
			vim.keymap.set({ "n", "x" }, "<leader>or", function() 
				require("opencode").prompt("review") 
			end, { desc = "Review code with AI" })
			
			vim.keymap.set({ "n", "x" }, "<leader>oe", function() 
				require("opencode").prompt("explain") 
			end, { desc = "Explain code with AI" })
			
			vim.keymap.set({ "n", "x" }, "<leader>of", function() 
				require("opencode").prompt("fix") 
			end, { desc = "Fix diagnostics with AI" })
			
			vim.keymap.set({ "n", "x" }, "<leader>od", function() 
				require("opencode").prompt("document") 
			end, { desc = "Document code with AI" })

			-- 设置事件处理
			vim.api.nvim_create_autocmd("User", {
				pattern = "OpencodeEvent:*",
				callback = function(args)
					---@type opencode.cli.client.Event
					local event = args.data.event
					---@type number
					local port = args.data.port

					-- 处理不同的 opencode 事件
					if event.type == "session.idle" then
						-- AI 响应完成
						vim.notify("opencode finished responding", vim.log.levels.INFO)
					elseif event.type == "file.edit" then
						-- 文件被编辑
						vim.notify("File edited by opencode", vim.log.levels.INFO)
					end
				end,
			})

			-- 创建用户命令
			vim.api.nvim_create_user_command("OpencodeAsk", function(opts)
				require("opencode").ask(opts.args)
			end, {
				nargs = "*",
				desc = "Ask opencode AI",
			})

			vim.api.nvim_create_user_command("OpencodeToggle", function()
				require("opencode").toggle()
			end, {
				desc = "Toggle opencode terminal",
			})

			vim.api.nvim_create_user_command("OpencodeSelect", function()
				require("opencode").select()
			end, {
				desc = "Select opencode action",
			})

			-- 服务器管理命令
			vim.api.nvim_create_user_command("OpencodeServerStart", function()
				vim.cmd('terminal opencode serve --port 4096')
				vim.notify("Starting opencode server on port 4096", vim.log.levels.INFO)
			end, {
				desc = "Start opencode server",
			})

			vim.api.nvim_create_user_command("OpencodeServerStatus", function()
				vim.fn.jobstart({ 'curl', '-s', 'http://127.0.0.1:4096/health' }, {
					on_exit = function(_, exit_code)
						if exit_code == 0 then
							vim.notify("opencode server is running on port 4096", vim.log.levels.INFO)
						else
							vim.notify("opencode server is not responding", vim.log.levels.WARN)
						end
					end,
				})
			end, {
				desc = "Check opencode server status",
			})
		end,

		-- 懒加载条件
		cmd = { "OpencodeAsk", "OpencodeToggle", "OpencodeSelect" },
		keys = {
			{ "<C-a>", mode = { "n", "x" }, desc = "Ask opencode AI" },
			{ "<C-x>", mode = { "n", "x" }, desc = "Execute opencode action" },
			{ "<C-.>", mode = { "n", "t" }, desc = "Toggle opencode" },
			{ "go", mode = { "n", "x" }, desc = "Add range to opencode" },
			{ "<leader>oo", desc = "Open opencode prompt" },
			{ "<leader>op", desc = "Select opencode prompt" },
			{ "<leader>or", mode = { "n", "x" }, desc = "Review code with AI" },
			{ "<leader>oe", mode = { "n", "x" }, desc = "Explain code with AI" },
			{ "<leader>of", mode = { "n", "x" }, desc = "Fix diagnostics with AI" },
			{ "<leader>od", mode = { "n", "x" }, desc = "Document code with AI" },
		},
	},
}